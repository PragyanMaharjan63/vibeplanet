PORT=5674
MONGO_URI=mongodb://mongo:27017/web1
REDIS_URL=redis://redis:6379

# Generate your own with: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-hex-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_SECONDS=2592000

# Set to "true" once served over HTTPS in production (required for cookies
# to be sent — browsers drop "Secure" cookies over plain HTTP).
COOKIE_SECURE=false

# Seeds a single admin account on first startup. Change the password here
# and restart the backend to rotate it (see README for details).
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-admin-password
