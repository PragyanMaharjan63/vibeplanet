# Used by docker-compose.yml for port mapping and build args
FRONTEND_PORT=3671
BACKEND_PORT=5674
MONGO_PORT=26712
REDIS_PORT=26379

# Leave empty so the frontend calls same-origin relative /api paths (proxied
# to the backend by nginx). Only set this if the backend is on a different
# domain than the frontend.
VITE_API_URL=

# How often the backup service dumps MongoDB, and how many days of dumps to
# keep in ./backups before older ones are auto-deleted.
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=7
