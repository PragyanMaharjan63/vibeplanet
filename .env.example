# Single .env for the whole project. docker-compose.yml reads this directly
# for ports/build-args, and the backend container gets it via env_file too.
# Copy this to .env and fill in real values.

# --- docker-compose ports / build args ---
FRONTEND_PORT=3671
BACKEND_PORT=5674
MONGO_PORT=26712
REDIS_PORT=26379

# Leave empty so the frontend calls same-origin relative /api paths (proxied
# to the backend by nginx). Only set this if the backend is on a different
# domain than the frontend.
VITE_API_URL=

# How often the backup service dumps MongoDB, and how many days of dumps to
# keep in ./backups before older ones are auto-deleted.
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=7

# --- backend ---
PORT=5674
MONGO_URI=mongodb://mongo:27017/web1
REDIS_URL=redis://redis:6379

# Generate your own with: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-hex-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_SECONDS=2592000

# Set to "true" once served over HTTPS in production (required for cookies
# to be sent — browsers drop "Secure" cookies over plain HTTP).
COOKIE_SECURE=false

# Seeds a single admin account on first startup. Change the password here
# and restart the backend to rotate it (see README for details).
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-admin-password
